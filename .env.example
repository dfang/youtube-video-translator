# YouTube Video Translator - Environment Configuration
# 复制此文件为 .env 并填入你的 API Key

# ElevenLabs API Key (必需)
# 获取地址：https://elevenlabs.io → Profile → API Keys
ELEVENLABS_API_KEY="你的 API 密钥填在这里"

# 大模型翻译配置（必需，已禁用 Google Translate 回退）
# 方案 A：Anthropic 官方
# ANTHROPIC_AUTH_TOKEN="sk-ant-xxx"
# ANTHROPIC_BASE_URL="https://api.anthropic.com"
# ANTHROPIC_MODEL="claude-3-7-sonnet-20250219"
#
# 方案 B：阿里云 Coding Plan（Anthropic 兼容网关）
ANTHROPIC_AUTH_TOKEN="sk-sp-xxx"
ANTHROPIC_BASE_URL="https://coding.dashscope.aliyuncs.com/apps/anthropic"
# 建议显式设置你账号可用模型，避免 400
ANTHROPIC_MODEL="qwen3-coder-plus"
# 可选：翻译请求超时（秒）
TRANSLATE_TIMEOUT_SINGLE="120"
TRANSLATE_TIMEOUT_BATCH="360"
# 可选：翻译请求重试（仅大模型，不会回退 Google）
TRANSLATE_RETRY_TIMES="3"
TRANSLATE_RETRY_BACKOFF_SEC="2"

# 可选配置
# ELEVENLABS_MODEL="eleven_multilingual_v2"
# ELEVENLABS_STABILITY="0.5"
# ELEVENLABS_SIMILARITY_BOOST="0.75"
